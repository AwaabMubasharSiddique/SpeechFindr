# ── Free-tier Groq keys (one per feature to spread the free-tier limits) ──
GROQ_API_KEY=your_transcription_key_here
GROQ_SUMMARY_API_KEY=your_summary_key_here
GROQ_ANALYSIS_API_KEY=your_qa_topics_chapters_key_here
GROQ_TRANSLATION_API_KEY_1=your_translation_key_1_here
GROQ_TRANSLATION_API_KEY_2=your_translation_key_2_here

# ── Paid Groq (optional) ──
# Paste a paid key here and everything (transcription, summary, analysis,
# translation) switches to it automatically — no code changes needed.
# The UI "API: Free/Paid" toggle then lets you flip between modes at runtime.
GROQ_PAID_API_KEY=
# Initial tier on startup: free | paid. Leave empty to auto-detect
# (paid when GROQ_PAID_API_KEY is set, free otherwise).
GROQ_TIER=

# ── Optional performance overrides (sensible defaults are picked per tier) ──
# Whisper chunk length in seconds (default 600) and parallel uploads
# (default: 4 free / 12 paid).
#UPLOAD_CHUNK_SECONDS=600
#UPLOAD_MAX_PARALLEL=4
# Groq translation pacing (default: 10000 tokens/min free / 250000 paid).
#TRANSLATION_TOKENS_PER_MIN=10000
#TRANSLATION_MAX_PARALLEL=2
# Prefer Google (free, fast) over Groq LLM for translation. Default: true on
# free tier, false on paid.
#TRANSLATION_PREFER_GOOGLE=true
# TTS engine: edge (Microsoft neural voices, fast) | gtts. Default: edge.
#TTS_ENGINE=edge
#TTS_MAX_CHARS=20000

# ── YouTube download ──
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_PROXY=
HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36
